# Server Configuration
HOST=127.0.0.1
PORT=8080
RUST_LOG=info

# Database – this app connects to PostgreSQL (Supabase DB), not the Supabase REST API.
# Get the Postgres connection string: Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Use the DATABASE PASSWORD (not the anon/publishable key). You can reset it in that same page if needed.
#
# (A) Full Postgres URI (password inside):
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-DATABASE-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# (B) URL without password + password in a separate env (e.g. DATABASE_SERVICE_KEY in secrets):
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]
DATABASE_SERVICE_KEY=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback

# Allowed admin GitHub username
ADMIN_GITHUB_USERNAME=kadynjaipearce

# Session secret (generate with: openssl rand -base64 64)
SESSION_SECRET=

# Contact email (where to receive contact form submissions)
CONTACT_EMAIL=

# Resend Email Service (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Public site URL (used for blog links in tweets and elsewhere)
SITE_BASE_URL=https://yourdomain.com

# Twitter/X – auto-post when you publish a blog post. Get an OAuth 2.0 User Access Token from
# developer.x.com → your project → User authentication → Generate access token (optional).
TWITTER_ACCESS_TOKEN=

# OpenRouter – used for \"Rewrite with AI\" in the admin blog editor
OPENROUTER_API_KEY=
# Optional: override default model (qwen/qwen-3.5-32b-a3b). Fallback is openai/gpt-4o-mini
OPENROUTER_MODEL=
